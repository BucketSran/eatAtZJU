# Browser-safe Supabase values. These may be used by Vite frontend code only with strict RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only values. Never expose these to browser code and never commit real values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=server_only_do_not_expose
SUPABASE_DB_URL=server_only_for_migrations_optional
SUPABASE_DISABLE_FALLBACK=false
