page {
  min-height: 100%;
  color: #31271d;
  background: linear-gradient(180deg, #fbf4e7 0%, #f6ead9 42%, #fffaf1 100%);
  font-family: "PingFang SC", "Hiragino Sans GB", "Source Han Serif SC", serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(49, 39, 29, 0.08);
  border-radius: 44rpx;
  background: linear-gradient(135deg, #fff7e7 0%, #f1d1a4 52%, #d96e3f 100%);
  box-shadow: 0 26rpx 70rpx rgba(128, 76, 35, 0.18);
}

.hero-card::before {
  position: absolute;
  top: -100rpx;
  right: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 250, 241, 0.42);
  content: '';
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 42rpx 0 22rpx;
}

.section-title-main {
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.section-title-sub {
  color: #8a6a4e;
  font-size: 24rpx;
}

.chip-row {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 6rpx;
  white-space: nowrap;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  padding: 18rpx 24rpx;
  border: 2rpx solid rgba(80, 57, 38, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.78);
  color: #6d5945;
  font-size: 25rpx;
}

.chip.active {
  border-color: rgba(176, 74, 43, 0.28);
  background: #b04a2b;
  color: #fffaf1;
  box-shadow: 0 16rpx 38rpx rgba(176, 74, 43, 0.22);
}

.empty-card {
  padding: 54rpx 34rpx;
  border: 2rpx dashed rgba(118, 91, 62, 0.22);
  border-radius: 36rpx;
  background: rgba(255, 250, 241, 0.72);
  color: #8a6a4e;
  text-align: center;
}

.primary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: #31271d;
  color: #fffaf1;
  font-weight: 700;
  box-shadow: 0 18rpx 46rpx rgba(49, 39, 29, 0.22);
}

.secondary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.75);
  color: #493728;
  font-weight: 700;
}
