.home-hero {
  padding: 42rpx 36rpx 38rpx;
}

.eyebrow {
  position: relative;
  z-index: 1;
  color: rgba(49, 39, 29, 0.62);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-title {
  position: relative;
  z-index: 1;
  max-width: 520rpx;
  margin-top: 22rpx;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.08;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  max-width: 560rpx;
  margin-top: 22rpx;
  color: rgba(49, 39, 29, 0.72);
  font-size: 27rpx;
  line-height: 1.55;
}

.hero-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.random-card {
  margin-top: 26rpx;
  padding: 28rpx 30rpx;
  border-radius: 32rpx;
  background: #31271d;
  color: #fffaf1;
  box-shadow: 0 22rpx 50rpx rgba(49, 39, 29, 0.2);
}

.random-label {
  color: rgba(255, 250, 241, 0.62);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.random-name {
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.random-meta {
  margin-top: 10rpx;
  color: rgba(255, 250, 241, 0.72);
  font-size: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 92rpx;
  margin-top: 32rpx;
  padding: 0 28rpx;
  border: 2rpx solid rgba(49, 39, 29, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.9);
  box-shadow: 0 16rpx 38rpx rgba(91, 61, 38, 0.1);
}

.search-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0d7b7;
  color: #7d4c27;
  font-size: 22rpx;
  font-weight: 800;
}

.search-box input {
  flex: 1;
  height: 100%;
  color: #31271d;
  font-size: 26rpx;
}

.time-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 24rpx;
  padding: 26rpx 28rpx;
  border: 2rpx solid rgba(10, 132, 255, 0.12);
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(239, 248, 255, 0.92), rgba(255, 250, 241, 0.9));
  box-shadow: 0 16rpx 36rpx rgba(25, 80, 130, 0.08);
}

.time-label {
  color: #0a84ff;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.time-title {
  margin-top: 10rpx;
  color: #31271d;
  font-size: 31rpx;
  font-weight: 900;
}

.time-copy {
  margin-top: 8rpx;
  color: rgba(49, 39, 29, 0.64);
  font-size: 23rpx;
  line-height: 1.45;
}

.time-badge {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(10, 132, 255, 0.1);
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 800;
}

.compact-section-title {
  margin-top: 24rpx;
}

.price-row {
  display: flex;
  gap: 14rpx;
  margin: 22rpx 0 0;
}

.price-pill {
  flex: 1;
  height: 70rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 241, 0.72);
  color: #756d5e;
  font-size: 24rpx;
  font-weight: 700;
}

.price-pill.active {
  background: #e2a14d;
  color: #fffaf1;
}
