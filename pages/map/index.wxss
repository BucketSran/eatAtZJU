.map-page {
  min-height: 100vh;
  background: #f6ead9;
}

.map-wrap {
  position: relative;
  height: 610rpx;
  overflow: hidden;
  border-bottom-left-radius: 44rpx;
  border-bottom-right-radius: 44rpx;
  box-shadow: 0 24rpx 60rpx rgba(78, 53, 35, 0.2);
}

.campus-map {
  width: 100%;
  height: 100%;
}

.map-badge {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 30rpx;
  background: rgba(49, 39, 29, 0.86);
  color: #fffaf1;
  backdrop-filter: blur(18rpx);
}

.badge-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
}

.badge-subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 250, 241, 0.72);
  font-size: 23rpx;
}

.map-list-shell {
  padding-top: 10rpx;
}

.map-title {
  margin-top: 26rpx;
}
