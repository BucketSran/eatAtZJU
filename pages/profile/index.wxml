<view class="page-shell profile-page">
  <view class="profile-hero">
    <view wx:if="{{profile.avatarType !== 'custom'}}" class="avatar" style="background: {{avatar.color}};">{{avatar.text}}</view>
    <image wx:else class="avatar avatar-image" src="{{profile.avatarTempPath}}" mode="aspectFill" />
    <view class="profile-copy">
      <view class="hello">{{profile.username}}</view>
      <view class="sub">当前偏好：{{preferenceText}}</view>
      <view class="sync-state">{{profileSynced ? '已同步到云端名片' : '本地名片，登录云环境后自动同步'}}</view>
    </view>
  </view>

  <view class="section-title">
    <text class="section-title-main">个人名片</text>
    <text class="section-title-sub">之后会展示在评论和打卡里</text>
  </view>
  <view class="profile-editor">
    <input class="username-input" value="{{profile.username}}" maxlength="16" placeholder="取一个浙大饭搭子昵称" bindblur="updateUsername" confirm-type="done" />
    <view class="avatar-grid">
      <button wx:for="{{avatarOptions}}" wx:key="id" class="avatar-choice {{profile.avatarType === 'preset' && profile.avatarPreset === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="choosePresetAvatar">
        <text class="avatar-choice-mark" style="background: {{item.color}};">{{item.text}}</text>
        <text>{{item.label}}</text>
      </button>
    </view>
    <button class="upload-button" bindtap="chooseCustomAvatar">上传自定义头像（小于 0.5MB）</button>
  </view>

  <view class="section-title">
    <text class="section-title-main">绑定浙大邮箱</text>
    <text class="section-title-sub">绑定后微信和邮箱共用同一个账号</text>
  </view>
  <view class="bind-card">
    <view class="bind-copy">先用微信进入小程序也没关系。绑定校园邮箱后，用户名、头像和偏好会合并；有冲突时你可以自己选保留哪边。</view>
    <input class="username-input" type="text" value="{{bindEmail}}" placeholder="yourname@zju.edu.cn" bindinput="updateBindEmail" />
    <view class="otp-row">
      <input class="username-input otp-input" type="number" value="{{bindOtp}}" maxlength="8" placeholder="邮箱验证码" bindinput="updateBindOtp" />
      <button class="send-code-button" loading="{{isBindingEmail}}" bindtap="sendBindOtp">发验证码</button>
    </view>
    <button class="upload-button" loading="{{isBindingEmail}}" bindtap="previewEmailBind">验证并预览合并</button>
    <view wx:if="{{bindStatus}}" class="bind-status">{{bindStatus}}</view>
  </view>

  <view wx:if="{{pendingMerge}}" class="merge-card">
    <view class="merge-title">资料冲突处理</view>
    <view class="merge-sub">邮箱：{{pendingMerge.email}}</view>

    <view class="merge-field">
      <view class="merge-label">用户名</view>
      <radio-group bindchange="chooseDisplayNameMerge">
        <label class="merge-option">
          <radio value="source" checked="{{mergeChoices.displayName === 'source'}}" />
          <text>保留微信：{{pendingMerge.preview.source.displayName}}</text>
        </label>
        <label class="merge-option">
          <radio value="target" checked="{{mergeChoices.displayName === 'target'}}" />
          <text>保留邮箱：{{pendingMerge.preview.target.displayName}}</text>
        </label>
      </radio-group>
    </view>

    <view class="merge-field">
      <view class="merge-label">头像</view>
      <radio-group bindchange="chooseAvatarMerge">
        <label class="merge-option">
          <radio value="source" checked="{{mergeChoices.avatar === 'source'}}" />
          <text>保留微信头像</text>
        </label>
        <label class="merge-option">
          <radio value="target" checked="{{mergeChoices.avatar === 'target'}}" />
          <text>保留邮箱头像</text>
        </label>
      </radio-group>
    </view>

    <view class="merge-field">
      <view class="merge-label">口味偏好</view>
      <radio-group bindchange="choosePreferenceMerge">
        <label class="merge-option">
          <radio value="union" checked="{{mergeChoices.preferences === 'union'}}" />
          <text>合并两边：{{pendingMerge.preview.unionPreferences}}</text>
        </label>
        <label class="merge-option">
          <radio value="source" checked="{{mergeChoices.preferences === 'source'}}" />
          <text>只保留微信：{{pendingMerge.preview.source.preferences}}</text>
        </label>
        <label class="merge-option">
          <radio value="target" checked="{{mergeChoices.preferences === 'target'}}" />
          <text>只保留邮箱：{{pendingMerge.preview.target.preferences}}</text>
        </label>
      </radio-group>
    </view>

    <button class="confirm-bind-button" loading="{{isBindingEmail}}" bindtap="confirmEmailBind">确认合并账号</button>
  </view>

  <view class="section-title">
    <text class="section-title-main">口味档案</text>
    <text class="section-title-sub">点一下就会影响推荐</text>
  </view>
  <view class="preference-grid">
    <button wx:for="{{tags}}" wx:key="label" class="pref-chip {{item.active ? 'active' : ''}}" data-tag="{{item.label}}" bindtap="togglePreference">{{item.label}}</button>
  </view>
  <button class="reset-button" bindtap="resetPreferences">恢复默认：近 / 实惠 / 辣</button>

  <view class="section-title">
    <text class="section-title-main">MVP 边界</text>
    <text class="section-title-sub">这版先跑体验</text>
  </view>
  <view class="mvp-card">
    <view class="mvp-title">当前版本已实现</view>
    <view class="mvp-copy">餐厅列表、筛选搜索、地图点位、详情、收藏、本地偏好推荐、随机吃什么。</view>
  </view>

  <view class="section-title">
    <text class="section-title-main">下一阶段</text>
    <text class="section-title-sub">从 vibe 到产品</text>
  </view>
  <view class="roadmap-list">
    <view wx:for="{{roadmap}}" wx:key="*this" class="roadmap-item">
      <text class="dot"></text>
      <text>{{item}}</text>
    </view>
  </view>
</view>
