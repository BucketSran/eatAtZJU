.profile-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 34rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #31271d 0%, #6c4b2f 54%, #e2a14d 100%);
  color: #fffaf1;
  box-shadow: 0 26rpx 70rpx rgba(49, 39, 29, 0.22);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border: 3rpx solid rgba(255, 250, 241, 0.64);
  border-radius: 34rpx;
  color: #fffaf1;
  font-size: 48rpx;
  font-weight: 950;
  box-shadow: inset 0 -10rpx 22rpx rgba(49, 39, 29, 0.18);
}

.avatar-image {
  display: block;
  background: #fffaf1;
}

.profile-copy {
  flex: 1;
}

.hello {
  font-size: 38rpx;
  font-weight: 950;
}

.sub {
  margin-top: 10rpx;
  color: rgba(255, 250, 241, 0.72);
  font-size: 24rpx;
  line-height: 1.45;
}

.sync-state {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.14);
  color: rgba(255, 250, 241, 0.78);
  font-size: 20rpx;
  font-weight: 800;
}

.profile-editor {
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 250, 241, 0.86);
  box-shadow: 0 18rpx 46rpx rgba(91, 61, 38, 0.1);
}

.username-input {
  height: 82rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(49, 39, 29, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #31271d;
  font-size: 28rpx;
  font-weight: 800;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.avatar-choice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 142rpx;
  padding: 14rpx 8rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: rgba(240, 224, 204, 0.52);
  color: #6d5945;
  font-size: 21rpx;
  font-weight: 800;
}

.avatar-choice.active {
  border-color: rgba(176, 74, 43, 0.5);
  background: rgba(176, 74, 43, 0.1);
}

.avatar-choice-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  color: #fffaf1;
  font-size: 28rpx;
  font-weight: 950;
}

.upload-button {
  width: 100%;
  height: 76rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: #31271d;
  color: #fffaf1;
  font-size: 24rpx;
  font-weight: 850;
}

.bind-card,
.merge-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 250, 241, 0.9);
  box-shadow: 0 18rpx 46rpx rgba(91, 61, 38, 0.1);
}

.bind-copy,
.merge-sub,
.bind-status {
  color: #6d5945;
  font-size: 24rpx;
  line-height: 1.55;
}

.bind-card .username-input {
  margin-top: 18rpx;
}

.otp-row {
  display: grid;
  grid-template-columns: 1fr 176rpx;
  gap: 14rpx;
  margin-top: 16rpx;
}

.otp-input {
  margin-top: 0 !important;
}

.send-code-button {
  height: 82rpx;
  border-radius: 24rpx;
  background: #efe0cc;
  color: #5d4a39;
  font-size: 23rpx;
  font-weight: 850;
}

.bind-status {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(176, 74, 43, 0.08);
}

.merge-title {
  color: #31271d;
  font-size: 34rpx;
  font-weight: 950;
}

.merge-field {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(240, 224, 204, 0.42);
}

.merge-label {
  margin-bottom: 12rpx;
  color: #31271d;
  font-size: 25rpx;
  font-weight: 900;
}

.merge-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 58rpx;
  color: #5d4a39;
  font-size: 24rpx;
  line-height: 1.45;
}

.confirm-bind-button {
  width: 100%;
  height: 82rpx;
  margin-top: 24rpx;
  border-radius: 26rpx;
  background: #b04a2b;
  color: #fffaf1;
  font-size: 26rpx;
  font-weight: 900;
}

.preference-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pref-chip {
  padding: 19rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.82);
  color: #6d5945;
  font-size: 25rpx;
  font-weight: 750;
}

.pref-chip.active {
  background: #b04a2b;
  color: #fffaf1;
  box-shadow: 0 16rpx 38rpx rgba(176, 74, 43, 0.2);
}

.reset-button {
  width: 100%;
  height: 78rpx;
  margin-top: 22rpx;
  border-radius: 24rpx;
  background: #efe0cc;
  color: #6d5945;
  font-size: 25rpx;
  font-weight: 800;
}

.mvp-card {
  padding: 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 250, 241, 0.86);
  box-shadow: 0 18rpx 46rpx rgba(91, 61, 38, 0.1);
}

.mvp-title {
  font-size: 31rpx;
  font-weight: 900;
}

.mvp-copy {
  margin-top: 14rpx;
  color: #6d5945;
  font-size: 25rpx;
  line-height: 1.55;
}

.roadmap-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.roadmap-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 250, 241, 0.75);
  color: #5d4a39;
  font-size: 25rpx;
  line-height: 1.45;
}

.dot {
  flex: 0 0 auto;
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #b04a2b;
}
