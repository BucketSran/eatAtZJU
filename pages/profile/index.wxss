.profile-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 34rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #31271d 0%, #6c4b2f 54%, #e2a14d 100%);
  color: #fffaf1;
  box-shadow: 0 26rpx 70rpx rgba(49, 39, 29, 0.22);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border: 3rpx solid rgba(255, 250, 241, 0.5);
  border-radius: 34rpx;
  background: rgba(255, 250, 241, 0.14);
  font-size: 48rpx;
  font-weight: 950;
}

.profile-copy {
  flex: 1;
}

.hello {
  font-size: 38rpx;
  font-weight: 950;
}

.sub {
  margin-top: 10rpx;
  color: rgba(255, 250, 241, 0.72);
  font-size: 24rpx;
  line-height: 1.45;
}

.preference-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pref-chip {
  padding: 19rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.82);
  color: #6d5945;
  font-size: 25rpx;
  font-weight: 750;
}

.pref-chip.active {
  background: #b04a2b;
  color: #fffaf1;
  box-shadow: 0 16rpx 38rpx rgba(176, 74, 43, 0.2);
}

.reset-button {
  width: 100%;
  height: 78rpx;
  margin-top: 22rpx;
  border-radius: 24rpx;
  background: #efe0cc;
  color: #6d5945;
  font-size: 25rpx;
  font-weight: 800;
}

.mvp-card {
  padding: 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 250, 241, 0.86);
  box-shadow: 0 18rpx 46rpx rgba(91, 61, 38, 0.1);
}

.mvp-title {
  font-size: 31rpx;
  font-weight: 900;
}

.mvp-copy {
  margin-top: 14rpx;
  color: #6d5945;
  font-size: 25rpx;
  line-height: 1.55;
}

.roadmap-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.roadmap-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 250, 241, 0.75);
  color: #5d4a39;
  font-size: 25rpx;
  line-height: 1.45;
}

.dot {
  flex: 0 0 auto;
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #b04a2b;
}
