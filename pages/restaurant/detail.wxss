.detail-page {
  min-height: 100vh;
  background: #fffaf1;
}

.detail-hero {
  position: relative;
  min-height: 520rpx;
  overflow: hidden;
  color: #fffaf1;
}

.hero-noise {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 20%, rgba(255,255,255,0.26), transparent 28%),
    radial-gradient(circle at 82% 10%, rgba(49,39,29,0.22), transparent 34%),
    linear-gradient(180deg, rgba(49,39,29,0.02), rgba(49,39,29,0.42));
}

.hero-icon {
  position: absolute;
  top: 54rpx;
  right: 44rpx;
  color: rgba(255, 250, 241, 0.28);
  font-size: 210rpx;
  font-weight: 900;
}

.hero-copy {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 52rpx;
}

.area {
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  opacity: 0.78;
}

.name {
  margin-top: 18rpx;
  font-size: 58rpx;
  font-weight: 950;
  line-height: 1.06;
}

.summary {
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  opacity: 0.86;
}

.detail-shell {
  margin-top: -40rpx;
  padding-top: 0;
}

.quick-panel {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  overflow: hidden;
  border-radius: 34rpx;
  background: rgba(255, 250, 241, 0.96);
  box-shadow: 0 24rpx 58rpx rgba(49, 39, 29, 0.14);
}

.quick-item {
  padding: 24rpx 10rpx;
  text-align: center;
}

.quick-value {
  display: block;
  font-size: 31rpx;
  font-weight: 900;
}

.quick-label {
  display: block;
  margin-top: 8rpx;
  color: #8a6a4e;
  font-size: 20rpx;
}

.action-row {
  display: flex;
  gap: 14rpx;
  margin-top: 26rpx;
}

.action-main {
  flex: 1;
}

.scene-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.scene-card {
  min-height: 112rpx;
  padding: 24rpx 18rpx;
  border-radius: 28rpx;
  background: #f0dfc7;
  color: #5b412e;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.35;
}

.menu-list,
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.menu-item,
.comment-card {
  padding: 26rpx;
  border: 2rpx solid rgba(49, 39, 29, 0.08);
  border-radius: 30rpx;
  background: rgba(255, 250, 241, 0.82);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name {
  font-size: 29rpx;
  font-weight: 850;
}

.dish-heat {
  margin-top: 8rpx;
  color: #8a6a4e;
  font-size: 23rpx;
}

.dish-price {
  color: #b04a2b;
  font-size: 32rpx;
  font-weight: 900;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.comment-person {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.comment-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  color: #fffaf1;
  font-size: 24rpx;
  font-weight: 950;
}

.comment-user {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 850;
}

.comment-rating {
  color: #946019;
  font-size: 23rpx;
}

.comment-text {
  margin-top: 14rpx;
  color: #5d4a39;
  font-size: 25rpx;
  line-height: 1.55;
}
